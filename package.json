{
  "name": "pokemon-desktop-pet",
  "version": "0.1.0",
  "description": "A PMDCollab-powered Pokémon desktop pet",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.pokeproductivity.app",
    "productName": "PokéProductivity",
    "files": [
      "main.js",
      "preload.js",
      "src/**",
      "settings.json",
      "assets/**"
    ],
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }]
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "license": "ISC"
}
